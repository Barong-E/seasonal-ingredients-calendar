<?xml version="1.0" encoding="utf-8"?>
<!-- 명절 미니 (2×1): 좌측 이름 및 대표음식, 우측 강조된 D-Day -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_holiday">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_holiday_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎋 단오"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_main_food"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="대표: 수리취떡"
            android:textColor="@color/widget_text_secondary"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_dday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="D-19"
        android:textColor="@color/widget_holiday_accent"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1" />

</LinearLayout>
