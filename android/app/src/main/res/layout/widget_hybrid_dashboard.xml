<?xml version="1.0" encoding="utf-8"?>
<!-- 하이브리드 대시보드 (4×2): 좌측 명절 카운트다운, 우측 제철음식 3개 리스트 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/widget_bg_hybrid">

    <!-- 좌측 영역: 명절 카운트다운 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="다가오는 명절"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_holiday_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="단오 🎋"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_holiday_dday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="D-19"
            android:textColor="@color/widget_hybrid_accent"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 중앙 구분선 (View 대신 FrameLayout 사용) -->
    <FrameLayout
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="16dp"
        android:background="@color/widget_divider" />

    <!-- 우측 영역: 제철음식 3개 리스트 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_list_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5월 추천 제철"
            android:textColor="@color/widget_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <!-- 항목 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tv_item1_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥬"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_item1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="완두콩"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- 항목 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tv_item2_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐟"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_item2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="병어"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- 항목 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_item3_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍄"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_item3_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="느타리버섯"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
