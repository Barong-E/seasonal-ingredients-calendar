<?xml version="1.0" encoding="utf-8"?>
<!-- 하이브리드 스퀘어 (2×2): 상단 제철음식 추천, 하단 명절 D-Day -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg_hybrid">

    <!-- 상단: 제철음식 1개 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_seasonal_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥬"
            android:textSize="28sp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘의 추천"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_seasonal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="완두콩"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- 구분선 (View 대신 FrameLayout 사용) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="@color/widget_divider" />

    <!-- 하단: 명절 D-day -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_holiday_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="단오 🎋"
            android:textColor="@color/widget_text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_holiday_dday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="D-19"
            android:textColor="@color/widget_hybrid_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
