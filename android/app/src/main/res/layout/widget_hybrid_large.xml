<?xml version="1.0" encoding="utf-8"?>
<!-- 하이브리드 대형 (4×4): 제철음식 5개 + 명절 정보 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg_hybrid">

    <!-- 제철음식 헤더 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌿" android:textSize="13sp"/>
        <TextView android:id="@+id/tv_month_label"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="5dp"
            android:text="5월 제철음식" android:textColor="@color/widget_text_secondary" android:textSize="12sp"/>
        <TextView android:id="@+id/tv_count"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="총 12종" android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
    </LinearLayout>

    <!-- 구분선 -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="6dp" android:layout_marginBottom="4dp"
        android:background="@color/widget_divider"/>

    <!-- 제철음식 행 1 -->
    <LinearLayout android:id="@+id/row1" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/tv_emoji1" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="🥬" android:textSize="14sp"/>
        <TextView android:id="@+id/tv_name1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp"
            android:text="완두콩" android:textColor="@color/widget_text_primary"
            android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_cat1" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="채소"
            android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
    </LinearLayout>

    <!-- 제철음식 행 2 -->
    <LinearLayout android:id="@+id/row2" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/tv_emoji2" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="🥬" android:textSize="14sp"/>
        <TextView android:id="@+id/tv_name2" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp"
            android:text="부추" android:textColor="@color/widget_text_primary"
            android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_cat2" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="채소"
            android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
    </LinearLayout>

    <!-- 제철음식 행 3 -->
    <LinearLayout android:id="@+id/row3" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/tv_emoji3" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="🥬" android:textSize="14sp"/>
        <TextView android:id="@+id/tv_name3" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp"
            android:text="죽순" android:textColor="@color/widget_text_primary"
            android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_cat3" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="채소"
            android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
    </LinearLayout>

    <!-- 제철음식 행 4 -->
    <LinearLayout android:id="@+id/row4" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/tv_emoji4" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="🍎" android:textSize="14sp"/>
        <TextView android:id="@+id/tv_name4" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp"
            android:text="매실" android:textColor="@color/widget_text_primary"
            android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_cat4" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="과일"
            android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
    </LinearLayout>

    <!-- 제철음식 행 5 -->
    <LinearLayout android:id="@+id/row5" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/tv_emoji5" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="🐟" android:textSize="14sp"/>
        <TextView android:id="@+id/tv_name5" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp"
            android:text="멸치" android:textColor="@color/widget_text_primary"
            android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_cat5" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="해산물"
            android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
    </LinearLayout>

    <!-- 구분선 -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
        android:background="@color/widget_divider"/>

    <!-- 명절 섹션 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🎋" android:textSize="18sp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="8dp" android:orientation="vertical">
            <TextView android:id="@+id/tv_holiday_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="단오" android:textColor="@color/widget_hybrid_accent"
                android:textSize="16sp" android:textStyle="bold" android:maxLines="1"/>
            <TextView android:id="@+id/tv_main_food"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="수리취떡" android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_dday"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="D-19" android:textColor="@color/widget_text_primary"
            android:textSize="20sp" android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
