<?xml version="1.0" encoding="utf-8"?>
<!-- 하이브리드 배너 (4×1): 제철음식 1개 + 명절 D-Day -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_hybrid">

    <!-- 제철 섹션 -->
    <TextView
        android:id="@+id/tv_seasonal_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🥬"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tv_seasonal_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="5dp"
        android:text="완두콩"
        android:textColor="@color/widget_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- 세로 구분선 -->
    <View
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@color/widget_divider" />

    <!-- 명절 섹션 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎋"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tv_holiday_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="단오"
            android:textColor="@color/widget_hybrid_accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tv_dday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D-19"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
