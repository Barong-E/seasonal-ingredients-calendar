<?xml version="1.0" encoding="utf-8"?>
<!-- 하이브리드 배너 (4×1): 좌측 제철음식 1개, 우측 명절 D-Day -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_hybrid">

    <!-- 제철음식 영역 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_seasonal_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥬"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘의 제철"
                android:textColor="@color/widget_text_secondary"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tv_seasonal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="완두콩"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- 세로 구분선 (View 대신 FrameLayout 사용) -->
    <FrameLayout
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="@color/widget_divider" />

    <!-- 명절 영역 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_holiday_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎋"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_holiday_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="단오"
                android:textColor="@color/widget_text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_dday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D-19"
                android:textColor="@color/widget_hybrid_accent"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
