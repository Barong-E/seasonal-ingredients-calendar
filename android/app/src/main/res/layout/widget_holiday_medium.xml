<?xml version="1.0" encoding="utf-8"?>
<!-- 명절 중형 (4×2): 명절 이름 + D-Day + 대표음식 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg_holiday">

    <!-- 헤더: 다가오는 명절 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎋 다가오는 명절"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@color/widget_divider" />

    <!-- 명절 이름 + D-Day -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_holiday_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="단오"
            android:textColor="@color/widget_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_dday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D-19"
            android:textColor="@color/widget_holiday_accent"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 대표음식 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="대표음식 "
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_main_food"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="수리취떡"
            android:textColor="@color/widget_holiday_accent"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
