<?xml version="1.0" encoding="utf-8"?>
<!-- 하이브리드 중형 (4×2): 제철음식 2개(순환) + 명절 정보 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg_hybrid">

    <!-- 상단: 제철음식 2개 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tv_month_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="5월 제철"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 행 1 -->
        <LinearLayout android:id="@+id/row1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <TextView android:id="@+id/tv_emoji1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🥬" android:textSize="14sp"/>
            <TextView android:id="@+id/tv_name1"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="5dp"
                android:text="완두콩" android:textColor="@color/widget_text_primary"
                android:textSize="14sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/tv_cat1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="채소" android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
        </LinearLayout>

        <!-- 행 2 -->
        <LinearLayout android:id="@+id/row2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:id="@+id/tv_emoji2"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🥬" android:textSize="14sp"/>
            <TextView android:id="@+id/tv_name2"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="5dp"
                android:text="부추" android:textColor="@color/widget_text_primary"
                android:textSize="14sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/tv_cat2"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="채소" android:textColor="@color/widget_hybrid_accent" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="@color/widget_divider" />

    <!-- 하단: 명절 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎋"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_holiday_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="단오"
            android:textColor="@color/widget_hybrid_accent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_dday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D-19"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
